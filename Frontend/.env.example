# WALL.E Frontend — Environment Variables
# Copy this file to .env.local for local development.
# In production, set these in the Vercel dashboard → Project → Settings → Environment Variables.

# The base URL of the Render backend API
# Local:      http://localhost:5000/api
# Production: https://your-render-service.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api
